# Solana RPC (optional; default: public mainnet, rate-limited)
# For heavy use, get a free one at https://alchemy.com or https://quicknode.com
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Telegram (optional - only if you want to send the report via Telegram)
# Create a bot via @BotFather, then get your chat ID
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
